{
  "name": "@cloverleaf/standard",
  "version": "0.3.0",
  "description": "The Cloverleaf Interoperability Standard — schemas, agent contracts, and conformance pack.",
  "type": "module",
  "license": "MIT",
  "author": "Renato D'Arrigo <renato.darrigo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloverleaf-org/cloverleaf.git",
    "directory": "standard"
  },
  "homepage": "https://github.com/cloverleaf-org/cloverleaf#readme",
  "bugs": {
    "url": "https://github.com/cloverleaf-org/cloverleaf/issues"
  },
  "keywords": [
    "cloverleaf",
    "methodology",
    "ai-first",
    "rfc",
    "conformance",
    "json-schema",
