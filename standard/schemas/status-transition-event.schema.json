{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.example/schemas/status-transition-event.schema.json",
  "title": "StatusTransitionEvent",
  "description": "Emitted when a Work Item changes status.",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "work_item_id", "work_item_type", "from_status", "to_status", "actor"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "status_transition" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "work_item_id": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemId" },
    "work_item_type": { "type": "string", "enum": ["rfc", "spike", "plan", "task"] },
    "from_status": {
      "type": "string",
      "minLength": 1,
      "$comment": "Must be a valid status for the referenced work_item_type per its concrete schema. This invariant is enforced by consumers, not by this schema."
    },
    "to_status": {
      "type": "string",
      "minLength": 1,
      "$comment": "Must be a valid status for the referenced work_item_type per its concrete schema. This invariant is enforced by consumers, not by this schema."
    },
    "actor": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/actor" },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
