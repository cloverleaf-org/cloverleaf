{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.example/schemas/spike.schema.json",
  "title": "Spike",
  "description": "A Cloverleaf Discovery research/de-risk task answering one specific question raised by an RFC.",
  "type": "object",
  "required": ["id", "type", "status", "owner", "project", "title", "parent_rfc", "question", "method"],
  "properties": {
    "id": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemId" },
    "type": { "const": "spike" },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "abandoned"]
    },
    "owner": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/owner" },
    "project": { "type": "string", "minLength": 1 },
    "parent": {
      "description": "Generic Work Item parent link. For a Spike, tools should prefer parent_rfc as the authoritative reference.",
      "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemRefOrNull"
    },
    "relationships": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/relationshipType" },
          "target": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemRef" }
        },
        "additionalProperties": false
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "parent_rfc": {
      "description": "The RFC this Spike answers. Required and typed; authoritative parent reference for Spikes.",
      "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemRef"
    },
    "question": { "type": "string", "minLength": 1 },
    "method": { "type": "string", "enum": ["research", "prototype", "benchmark"] },
    "findings": { "type": "string", "minLength": 1, "description": "Evidence-backed answer. REQUIRED when status is 'completed'." },
    "recommendation": { "type": "string", "minLength": 1, "description": "Implication for the RFC / Plan. REQUIRED when status is 'completed'." },
    "extensions": { "$ref": "https://cloverleaf.example/schemas/extensions.schema.json" }
  },
  "additionalProperties": false,
  "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
  "then": {
    "required": ["findings", "recommendation"],
    "properties": {
      "findings": { "type": "string", "minLength": 1 },
      "recommendation": { "type": "string", "minLength": 1 }
    }
  }
}
