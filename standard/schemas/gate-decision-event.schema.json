{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.example/schemas/gate-decision-event.schema.json",
  "title": "GateDecisionEvent",
  "description": "Emitted when a human (or automated) gate renders a decision.",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "gate", "work_item_id", "decision", "approver"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "gate_decision" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "gate": {
      "type": "string",
      "enum": [
        "rfc_strategy_gate",
        "task_batch_gate",
        "per_task_plan_review",
        "final_approval_gate",
        "human_merge"
      ]
    },
    "work_item_id": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemRef" },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "revise", "split", "abandon", "escalate"],
      "$comment": "Decision/gate consistency (e.g., split applies to task_batch_gate; abandon applies to rfc_strategy_gate) is enforced by consumers, not by this schema."
    },
    "approver": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/actor" },
    "comment": { "type": "string", "description": "Free-text rationale or feedback from the approver." }
  },
  "additionalProperties": false
}
