{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.dev/schemas/rfc.schema.json",
  "title": "RFC",
  "description": "A Cloverleaf Discovery proposal.",
  "type": "object",
  "required": ["id", "type", "status", "owner", "title", "problem", "solution", "unknowns", "acceptance_criteria", "out_of_scope"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "const": "rfc" },
    "status": {
      "type": "string",
      "enum": ["drafting", "spike-in-flight", "planning", "gate-pending", "approved", "rejected", "abandoned"]
    },
    "owner": { "$ref": "https://cloverleaf.dev/schemas/work-item.schema.json#/$defs/owner" },
    "parent": { "type": ["string", "null"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "title": { "type": "string", "minLength": 1 },
    "problem": { "type": "string", "minLength": 1 },
    "solution": { "type": "string", "minLength": 1 },
    "unknowns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Each unknown is a candidate Spike."
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
