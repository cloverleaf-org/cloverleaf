{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.example/schemas/plan.schema.json",
  "title": "Plan",
  "description": "Output of Plan & Task Breakdown: finalized RFC + Task DAG + Tasks + path→reviewer mappings.",
  "$comment": "Runtime invariant (not enforceable by schema): the set of tasks[].id MUST equal the set of task_dag.nodes. Tools should validate this separately.",
  "type": "object",
  "required": ["id", "type", "status", "owner", "parent_rfc", "task_dag", "tasks"],
  "properties": {
    "id": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemId" },
    "type": { "const": "plan" },
    "status": {
      "type": "string",
      "enum": ["drafting", "gate-pending", "approved", "rejected"]
    },
    "owner": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/owner" },
    "parent": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemIdOrNull" },
    "dependencies": { "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/dependencyList" },
    "parent_rfc": {
      "description": "The RFC id this Plan implements.",
      "$ref": "https://cloverleaf.example/schemas/work-item.schema.json#/$defs/workItemId"
    },
    "task_dag": { "$ref": "https://cloverleaf.example/schemas/dependency-dag.schema.json" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://cloverleaf.example/schemas/task.schema.json" },
      "description": "Tasks emitted by this Plan. Each conforms to the Task schema."
    },
    "path_reviewer_map": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["pattern", "role"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "description": "Path-glob → reviewer-role mappings emitted from path analysis (suggestions only)."
    },
    "extensions": { "$ref": "https://cloverleaf.example/schemas/extensions.schema.json" }
  },
  "additionalProperties": false
}
