{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.example/schemas/path-rules.schema.json",
  "title": "PathRules",
  "description": "Project-defined path-glob → reviewer-role mappings. Suggestions only.",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["pattern", "role"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
