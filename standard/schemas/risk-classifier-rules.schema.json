{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloverleaf.dev/schemas/risk-classifier-rules.schema.json",
  "title": "RiskClassifierRules",
  "description": "Project-tunable rules for the deterministic Risk Classifier. Default classification is HIGH-RISK; downgrade to LOW-RISK requires ALL checks to pass.",
  "type": "object",
  "required": ["protected_paths", "public_api_paths", "schema_paths", "dependency_files", "ci_paths", "ui_paths", "thresholds"],
  "properties": {
    "protected_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Glob patterns. Any change to a matching path forces HIGH-RISK."
    },
    "public_api_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Globs for public API surface."
    },
    "schema_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Globs for data-model / schema / migration files."
    },
    "dependency_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ci_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ui_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "thresholds": {
      "type": "object",
      "required": ["max_loc_changed", "max_files_changed", "min_coverage_pct"],
      "properties": {
        "max_loc_changed": { "type": "integer", "minimum": 1 },
        "max_files_changed": { "type": "integer", "minimum": 1 },
        "min_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
