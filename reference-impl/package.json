{
  "name": "@cloverleaf/reference-impl",
  "version": "0.5.3",
  "description": "Reference implementation of the Cloverleaf methodology as Claude Code skills. Implements the Tight Loop (Implementer + Reviewer).",
  "type": "module",
  "license": "MIT",
  "author": "Renato D'Arrigo <renato.darrigo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloverleaf-org/cloverleaf.git",
    "directory": "reference-impl"
  },
  "homepage": "https://github.com/cloverleaf-org/cloverleaf#readme",
  "bugs": {
    "url": "https://github.com/cloverleaf-org/cloverleaf/issues"
  },
  "keywords": [
    "cloverleaf",
    "methodology",
    "ai-first",
    "claude-code",
    "agent",
    "reference-implementation"
  ],
  "files": [
    ".claude-plugin",
    "skills",
    "lib",
    "prompts",
    "config",
    "install.sh",
    "README.md",
    "VERSION",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cloverleaf-cli": "./dist/cli.mjs"
  },
  "scripts": {
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/rename-to-mjs.mjs",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@cloverleaf/standard": "^0.4.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axe-core": "^4.10.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.47.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
