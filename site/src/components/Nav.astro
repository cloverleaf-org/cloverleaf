---
import Mark from './Mark.astro';
import { url } from '../lib/url.js';
const links = [
  { href: '/guide', label: 'Guide', external: false },
  { href: '/start', label: 'Get started', external: false },
  { href: 'https://github.com/cloverleaf-org/cloverleaf/tree/main/standard', label: 'Standard', external: true },
  { href: '/faq', label: 'FAQ', external: false },
];
---
<nav class="site-nav">
  <a href={url('/')} class="brand">
    <Mark size={20} />
    <span class="brand-name">Cloverleaf</span>
  </a>
  <div class="nav-links">
    {links.map(link => link.external
      ? <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
      : <a href={url(link.href)}>{link.label}</a>
    )}
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 32px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: none;
  }
  .brand:hover { text-decoration: none; }
  .brand-name { letter-spacing: -0.005em; }
  .nav-links {
    display: flex;
    gap: 22px;
  }
  .nav-links a {
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
  }
  .nav-links a:hover { color: var(--color-ink); text-decoration: none; }
</style>
