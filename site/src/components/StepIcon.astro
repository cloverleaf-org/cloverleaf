---
interface Props {
  variant: 'agent' | 'gate';
  size?: number;
}
const { variant, size = 22 } = Astro.props;
const iconId = variant === 'agent' ? '#icon-robot' : '#icon-person';
const innerSize = Math.round(size * 0.59);
---
<span class={`step-icon ${variant}`} style={`width:${size}px;height:${size}px;`}>
  <svg width={innerSize} height={innerSize} viewBox="0 0 24 24" aria-hidden="true">
    <use href={iconId} />
  </svg>
</span>

<style>
  .step-icon {
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .step-icon.agent { color: var(--color-accent); }
  .step-icon.gate {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
