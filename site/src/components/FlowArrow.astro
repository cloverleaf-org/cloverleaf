---
interface Props {
  topLabel?: string;
  bottomLabel?: string;
}
const { topLabel = 'tasks', bottomLabel = 'feedback' } = Astro.props;
---
<div class="flow-arrow" aria-hidden="true">
  <svg width="22" height="22" viewBox="0 0 24 24"><use href="#icon-arrow-right"/></svg>
  <span>{topLabel}</span>
  <svg width="22" height="22" viewBox="0 0 24 24" style="transform:rotate(180deg);"><use href="#icon-arrow-right"/></svg>
  <span>{bottomLabel}</span>
</div>

<style>
  .flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--color-accent);
  }
  .flow-arrow span {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
