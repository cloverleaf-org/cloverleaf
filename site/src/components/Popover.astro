---
interface Props {
  triggerLabel: string;
}
const { triggerLabel } = Astro.props;
---
<details class="popover-details">
  <summary>
    <span class="pt-icon">?</span>
    {triggerLabel}
  </summary>
  <div class="popover">
    <div class="popover-tip"></div>
    <div class="popover-title"><slot name="title" /></div>
    <div class="popover-body"><slot /></div>
  </div>
</details>

<style>
  .popover-details { position: relative; }
  .popover-details > summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px 8px;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all 0.12s;
    user-select: none;
  }
  .popover-details > summary::-webkit-details-marker { display: none; }
  .popover-details > summary::marker { content: ''; }
  .popover-details > summary:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }
  .popover-details[open] > summary {
    background: var(--color-bg);
    color: var(--color-accent);
  }
  .popover-details > summary .pt-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .popover-details > summary:hover .pt-icon,
  .popover-details[open] > summary .pt-icon {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .popover {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 20;
    width: 340px;
    max-width: calc(100vw - 80px);
    background: var(--color-surface);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    padding: 18px 22px 18px 20px;
    box-shadow: 0 12px 36px rgba(13, 20, 33, 0.12), 0 2px 6px rgba(13, 20, 33, 0.06);
  }
  .popover-tip {
    position: absolute;
    top: -7px;
    right: 18px;
    width: 14px;
    height: 14px;
    background: var(--color-surface);
    transform: rotate(45deg);
    box-shadow: -2px -2px 4px rgba(13, 20, 33, 0.04);
  }
  .popover-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .popover-body {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--color-text-body);
  }
  .popover-body :global(p) { margin: 0 0 8px; }
  .popover-body :global(p:last-child) { margin-bottom: 0; }
</style>
