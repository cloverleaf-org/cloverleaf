---
const standardVersion = '0.3.0';
const date = '2026-04-20';
const repoUrl = 'https://github.com/cloverleaf-org/cloverleaf';
const licenseUrl = 'https://github.com/cloverleaf-org/cloverleaf/blob/main/LICENSE';
---
<footer class="site-footer">
  <div class="inner">
    <span>Cloverleaf Standard v{standardVersion} &middot; {date}</span>
    <span class="links">
      <a href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="sep">&middot;</span>
      <a href={licenseUrl} target="_blank" rel="noopener noreferrer">MIT</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 24px 32px;
    margin-top: var(--space-16);
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .links a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .links a:hover {
    color: var(--color-ink);
    text-decoration: underline;
  }
  .sep {
    margin: 0 8px;
  }
</style>
