---
interface Props {
  leftTitle: string;
  leftLabel: string;
  leftMeta: string;
  rightTitle: string;
  rightLabel: string;
  rightMeta: string;
  topArrowLabel?: string;
  bottomArrowLabel?: string;
}
const {
  leftTitle, leftLabel, leftMeta,
  rightTitle, rightLabel, rightMeta,
  topArrowLabel = 'tasks',
  bottomArrowLabel = 'questions'
} = Astro.props;
---
<div class="signature-loop">
  <div class="loop-track">
    <div class="label">{leftLabel}</div>
    <h3 class="track-title">{leftTitle}</h3>
    <div class="meta">{leftMeta}</div>
  </div>
  <div class="loop-arrows">
    <div class="arrow-with-label">
      <span class="al-label">{topArrowLabel}</span>
      <svg viewBox="0 0 84 14" width="84" height="14" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round">
        <path d="M 4 10 Q 42 -2, 78 10"/>
        <path d="M 73 6 L 78 10 L 73 14"/>
      </svg>
    </div>
    <div class="arrow-with-label">
      <svg viewBox="0 0 84 14" width="84" height="14" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round">
        <path d="M 80 4 Q 42 16, 6 4"/>
        <path d="M 11 0 L 6 4 L 11 8"/>
      </svg>
      <span class="al-label">{bottomArrowLabel}</span>
    </div>
  </div>
  <div class="loop-track">
    <div class="label">{rightLabel}</div>
    <h3 class="track-title">{rightTitle}</h3>
    <div class="meta">{rightMeta}</div>
  </div>
</div>

<style>
  .signature-loop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin: 0 0 36px;
    padding: 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .loop-track { padding: 14px 20px; text-align: center; }
  .loop-track .label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .loop-track .track-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 24px;
    margin: 0 0 4px;
    color: var(--color-ink);
  }
  .loop-track .meta { font-size: 11px; color: var(--color-text-muted); }
  .loop-arrows {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 0 24px;
  }
  .arrow-with-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }
  .al-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
</style>
