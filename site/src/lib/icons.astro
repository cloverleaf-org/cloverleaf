---
// Inline SVG defs included once in the document; components reference via <use href="#icon-name">
---
<svg width="0" height="0" style="position:absolute;" aria-hidden="true">
  <defs>
    <symbol id="icon-mark" viewBox="0 0 40 40">
      <line x1="20" y1="3" x2="20" y2="37" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="3" y1="20" x2="37" y2="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M 14 14 Q 14 8 20 8" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M 26 14 Q 26 8 20 8" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M 14 26 Q 14 32 20 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M 26 26 Q 26 32 20 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
