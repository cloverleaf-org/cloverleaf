    </symbol>
    <symbol id="icon-arrow-right" viewBox="0 0 24 24">
      <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2"/>
    </symbol>
  </defs>
