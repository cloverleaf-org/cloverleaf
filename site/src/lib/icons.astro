      <circle cx="9.5" cy="13.5" r="1.1" fill="currentColor"/>
      <circle cx="14.5" cy="13.5" r="1.1" fill="currentColor"/>
      <line x1="12" y1="9" x2="12" y2="6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
